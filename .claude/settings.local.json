{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm create:*)",
      "Bash(npm run:*)",
      "Bash(node:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "WebFetch(domain:docs.balldontlie.io)",
      "WebFetch(domain:www.balldontlie.io)",
      "WebFetch(domain:hoopshype.com)",
      "WebFetch(domain:fanspo.com)",
      "WebSearch",
      "Bash(xargs kill:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); fp=d.get('tool_input',{}).get('file_path',''); print('Invoke the code-reviewer agent on: '+(fp or 'the modified files'))\""
          }
        ]
      }
    ]
  }
}
